# ==========================================
# SERVIDOR
# ==========================================
NODE_ENV=development
PORT=5000
CORS_ORIGIN=http://localhost:3000

# ==========================================
# BASE DE DATOS
# ==========================================
DATABASE_URL=postgresql://usuario:contraseña@localhost:5432/contabilidad

# ==========================================
# GOOGLE DRIVE API
# ==========================================
# OAuth2 (para usuario autenticado)
GOOGLE_CLIENT_ID=tu_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu_client_secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/v1/auth/google/callback

# ID de la carpeta raíz en Google Drive (dejar vacío para crear una nueva)
GOOGLE_DRIVE_FOLDER_ID=

# Service Account (para automatización del backend)
# Descargar el JSON de la Service Account desde Google Cloud Console
GOOGLE_SERVICE_ACCOUNT_PATH=./config/service-account.json
