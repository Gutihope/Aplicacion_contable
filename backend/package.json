{
  "name": "contabilidad-backend",
  "version": "1.0.0",
  "description": "Backend de contabilidad personal con partida doble",
  "main": "src/server.ts",
  "scripts": {
    "dev": "ts-node --project tsconfig.json src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "type-check": "tsc --noEmit",
    "seed:base": "node scripts/seed-base.js",
    "seed:puc": "node scripts/seed-puc.js",
    "analyze:puc": "node scripts/analyze-puc.js"
  },
  "dependencies": {
    "@prisma/client": "^5.0.0",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "morgan": "^1.10.0",
    "dotenv": "^16.3.1",
    "multer": "^1.4.5-lts.1",
    "googleapis": "^118.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "^20.3.1",
    "@types/cors": "^2.8.13",
    "@types/morgan": "^1.9.5",
    "@types/multer": "^1.4.7",
    "typescript": "^5.1.3",
    "ts-node": "^10.9.1",
    "@types/express-serve-static-core": "^4.17.33",
    "prisma": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
